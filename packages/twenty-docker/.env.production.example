# Copy to ~/twenty-crm/.env on the VPS (never commit .env)
# See DEPLOY.md for the full deployment runbook
# docker compose -f docker-compose.prod.yml up -d

TAG=latest
SERVER_URL=https://crm.lakshitukani.com

# Supabase — URL-encode special chars in password; do not add ?sslmode=require
PG_DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres
PG_SSL_ALLOW_SELF_SIGNED=true
REDIS_URL=redis://redis:6379

# openssl rand -base64 32 — must match the key used when the DB was first initialized
ENCRYPTION_KEY=

IS_CONFIG_VARIABLES_IN_DB_ENABLED=false

STORAGE_TYPE=S_3
STORAGE_S3_NAME=
STORAGE_S3_REGION=
STORAGE_S3_ENDPOINT=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_PRESIGNED_URL_ENABLED=false
STORAGE_S3_PRESIGNED_URL_EXPIRES_IN=900
