TAG=latest

# Local Docker: docker compose up -d
# Production VPS: see DEPLOY.md and .env.production.example + docker-compose.prod.yml

# Supabase Postgres (same URL for local Docker and production)
# URL-encode special characters in the password (@ → %40, $ → %24, etc.)
# Do not add ?sslmode=require — it overrides PG_SSL_ALLOW_SELF_SIGNED
# PG_DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres
# PG_SSL_ALLOW_SELF_SIGNED=true  # required for Supabase session pooler from Docker
# REDIS_URL=redis://redis:6379

SERVER_URL=http://localhost:3000

# Use openssl rand -base64 32 for each secret
# ENCRYPTION_KEY=replace_me_with_a_random_string
# FALLBACK_ENCRYPTION_KEY= # set to the previous ENCRYPTION_KEY during a rotation
# APP_SECRET= # legacy: only required for instances that pre-date ENCRYPTION_KEY

STORAGE_TYPE=local

# STORAGE_S3_REGION=eu-west3
# STORAGE_S3_NAME=my-bucket
# STORAGE_S3_ENDPOINT=
# STORAGE_S3_ACCESS_KEY_ID=
# STORAGE_S3_SECRET_ACCESS_KEY=
